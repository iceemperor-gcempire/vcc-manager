# API Configuration
# For development (same origin)
REACT_APP_API_URL=/api
# For production with different ports, use full URL:
# REACT_APP_API_URL=http://localhost:3136/api

# Monitoring Update Intervals (milliseconds) — 미설정 시 기본값
# 작업 목록 폴링 주기 (기본 3000)
REACT_APP_RECENT_JOBS_INTERVAL=3000
# 큐 상태 폴링 주기 (기본 10000)
REACT_APP_QUEUE_STATUS_INTERVAL=10000
